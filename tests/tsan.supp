# ThreadSanitizer suppressions for running the test suite against a system
# Qt that is NOT built with TSan instrumentation.
#
# Synchronization performed inside libQt6Core — the QFutureInterface mutex
# guarding continuation setup/run, the signal/slot connection-list locks,
# and queued-event delivery — is invisible to TSan, so every access that
# crosses one of those edges is reported as a false race. All entries below
# are scoped to Qt's machinery; races rooted in QtCoroutine's own logic
# (qtask.hpp / qtcoroutine.hpp state, guards, control blocks) remain visible.
called_from_lib:libQt6Core.so.6

# QFuture continuation machinery (templates instantiated into our binary
# from Qt headers; the guarding mutex lives in the uninstrumented lib).
race:QtPrivate::Continuation
race:QtPrivate::ContinuationWrapper
race:QtPrivate::CanceledHandler
race:QFutureInterfaceBase
race:QtConcurrent::

# Qt's internal QPointer/QWeakPointer checks inside continuation wrappers.
race:QWeakPointer

# QtConcurrent's StoredFunctionCall runnable is allocated on the caller
# thread and freed on a pool thread; the handoff is QThreadPool's mutex,
# inside the uninstrumented lib. (File-based patterns: these frames are
# header templates inlined into our binary under short display names.)
race:qtconcurrentstoredfunctioncall.h
race:qtconcurrentrunbase.h
race:qtconcurrentrun.h
race:qfuture_impl.h

# glib event-loop internals (uninstrumented system library).
race:libglib-2.0.so
called_from_lib:libglib-2.0.so.0

# Cross-thread queued signal delivery hands the connection functor (and its
# captures: the ControlBlock shared_ptr, the coroutine handle) from the
# posting thread to the receiving thread under QCoreApplication's
# event-queue mutex — inside the uninstrumented lib, so TSan reports the
# handoff as a race on the captures and the resumed frame. These entries
# suppress the signal-delivery path and the test scaffolding only; QTask's
# promise and combinator synchronization (qtask.hpp) is self-contained and
# stays fully visible to TSan.
race:qtcoroutine.hpp
race:test_core.cpp
race:coroutine
race:qdeadlinetimer.h
